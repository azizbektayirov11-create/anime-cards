  { id:'konohamaru',name:'Konohamaru',            anime:'Naruto',           emoji:'🌀', rarity:'COMMON', power:1000, stars:2 },
  { id:'chopper',   name:'Tony Chopper',          anime:'One Piece',        emoji:'🦌', rarity:'COMMON', power:1100, stars:2 },
  { id:'krillin',   name:'Krillin',               anime:'Dragon Ball Z',    emoji:'🥚', rarity:'COMMON', power:1300, stars:2 },
];

// Rarity weights → probability
const RARITY_WEIGHTS = {
  COMMON:    55,
  RARE:      28,
  EPIC:      12,
  LEGENDARY:  4,
  MYTHIC:     1,
};

// ─────────────────────────────────────────────
//  STATE
// ─────────────────────────────────────────────
let gems = 300;
let totalPulls = 0;
let pity = 0;           // Pity counter for guaranteed legendary at 90
let collection = {};    // { charId: count }
let activeFilter = 'ALL';

// ─────────────────────────────────────────────
//  GACHA LOGIC
// ─────────────────────────────────────────────
function rollOne() {
  pity++;
  // Pity guarantee
  let forcedRarity = null;
  if (pity >= 90) { forcedRarity = 'LEGENDARY'; pity = 0; }

  let rarity;
  if (forcedRarity) {
    rarity = forcedRarity;
  } else {
    const rand = Math.random() * 100;
    if (rand < 1)       rarity = 'MYTHIC';
    else if (rand < 5)  rarity = 'LEGENDARY';
    else if (rand < 17) rarity = 'EPIC';
    else if (rand < 45) rarity = 'RARE';
    else                rarity = 'COMMON';
    // Reset pity on legendary+
    if (rarity === 'LEGENDARY' || rarity === 'MYTHIC') pity = 0;
  }

  const pool = CHARACTERS.filter(c => c.rarity === rarity);
  return pool[Math.floor(Math.random() * pool.length)];
}

function doPull(count) {
  const cost = count === 1 ? 30 : 280;
  if (gems < cost) {
    showToast('Kristall yetarli emas! 💎');
    return;
  }
  gems -= cost;
  totalPulls += count;

  const results = [];
  for (let i = 0; i < count; i++) results.push(rollOne());

  // Add to collection
  results.forEach(c => {
    collection[c.id] = (collection[c.id] || 0) + 1;
  });

  updateUI();
  showRollOverlay(results);
}

// ─────────────────────────────────────────────
//  RENDER
// ─────────────────────────────────────────────
function rarityLabel(r) {
  const map = { COMMON:'ODDIY', RARE:'NOYOB', EPIC:'EPIK', LEGENDARY:'AFSONAVIY', MYTHIC:'MIFIK' };
  return map[r] || r;
}

function makeCardHTML(char, delay=0) {
  const stars = '⭐'.repeat(char.stars);
  return `
    <div class="card rarity-${char.rarity}" style="animation-delay:${delay}ms">
      <div class="card-inner">
        <span class="card-emoji">${char.emoji}</span>
        <div class="card-anime">${char.anime}</div>
        <div class="card-name">${char.name}</div>
        <span class="card-rarity-badge">${rarityLabel(char.rarity)}</span>
        <div class="card-stars">${stars}</div>
        <div class="card-power">⚡<span class="pw">${char.power.toLocaleString()}</span></div>
      </div>
    </div>`;
}

function showRollOverlay(results) {
  const row = document.getElementById('roll-cards-row');
  row.innerHTML = results.map((c,i) => makeCardHTML(c, i*80)).join('');
  document.getElementById('roll-overlay').classList.add('active');

  // Spawn sparkles for legendary+
  results.forEach((c,i) => {
    if (c.rarity === 'LEGENDARY' || c.rarity === 'MYTHIC') {
      setTimeout(() => {
        for (let j=0;j<6;j++) spawnSparkle(
          window.innerWidth/2 + (Math.random()-.5)*400,
          window.innerHeight/2 + (Math.random()-.5)*300
        );
      }, i*80 + 400);
    }
  });
}

function closeOverlay() {
  document.getElementById('roll-overlay').classList.remove('active');
  renderCollection();
}

function updateUI() {
  document.getElementById('gems').textContent = gems;
  document.getElementById('total-pulls').textContent = totalPulls;
  document.getElementById('pity-count').textContent = pity + '/90';

  // Collection stats
  const counts = { COMMON:0, RARE:0, EPIC:0, LEGENDARY:0, MYTHIC:0 };
  Object.entries(collection).forEach(([id, cnt]) => {
    const c = CHARACTERS.find(x=>x.id===id);
    if (c) counts[c.rarity] += cnt;
  });
  const total = Object.values(counts).reduce((a,b)=>a+b,0);

  const sc = document.getElementById('coll-stats');
  const colors = { COMMON:'#7a9bb0', RARE:'#4a90e8', EPIC:'#a855f7', LEGENDARY:'#f59e0b', MYTHIC:'#ef4444' };
  sc.innerHTML = `
    <div class="coll-stat">🃏 Jami: <b style="color:var(--gold)">${total}</b></div>
    ${Object.entries(counts).filter(([,v])=>v>0).map(([r,v])=>`
      <div class="coll-stat"><span style="color:${colors[r]}">${rarityLabel(r)}: ${v}</span></div>
    `).join('')}
  `;
}

function renderCollection() {
  const grid = document.getElementById('coll-grid');
  const entries = Object.entries(collection);
  if (!entries.length) {
    grid.innerHTML = '<div class="empty-coll" style="grid-column:1/-1">Hali hech qanday carta yo\'q. Pull qiling! 🎴</div>';
    return;
  }

  // Filter
  let filtered = entries.map(([id,cnt]) => ({ char: CHARACTERS.find(x=>x.id===id), cnt }))
    .filter(e => e.char && (activeFilter === 'ALL' || e.char.rarity === activeFilter));

  // Sort by power desc
  filtered.sort((a,b) => b.char.power - a.char.power);

  if (!filtered.length) {
    grid.innerHTML = '<div class="empty-coll" style="grid-column:1/-1">Bu rarityda carta yo\'q.</div>';
    return;
  }

  const colorMap = { COMMON:'#7a9bb0', RARE:'#4a90e8', EPIC:'#a855f7', LEGENDARY:'#f59e0b', MYTHIC:'#ef4444' };

  grid.innerHTML = filtered.map(({char:c, cnt}) => `
    <div class="coll-card rarity-${c.rarity}" style="border-color:${colorMap[c.rarity]}30">
      ${cnt>1 ? `<div class="count-badge">x${cnt}</div>` : ''}
      <div style="font-size:2rem;margin-bottom:4px;filter:drop-shadow(0 2px 6px rgba(0,0,0,.5))">${c.emoji}</div>
      <div style="font-size:.6rem;color:#5a8aaa;letter-spacing:1px">${c.anime}</div>
      <div style="font-family:'Orbitron',monospace;font-size:.6rem;margin:3px 0;line-height:1.2">${c.name}</div>
      <div style="font-size:.6rem;color:${colorMap[c.rarity]};letter-spacing:1px">${rarityLabel(c.rarity)}</div>
      <div style="font-size:.65rem;color:var(--gold);font-family:'Orbitron',monospace;margin-top:3px">⚡${c.power.toLocaleString()}</div>
      <div style="font-size:.6rem;margin-top:2px">${'⭐'.repeat(c.stars)}</div>
    </div>
  `).join('');
}

function filterBy(rarity, btn) {
  activeFilter = rarity;
  document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderCollection();
}

function toggleRates() {
  document.getElementById('rates-panel').classList.toggle('open');
}

function spawnSparkle(x, y) {
  const emojis = ['✨','⭐','💫','🌟','💥','🔥'];
  const s = document.createElement('div');
  s.className = 'sparkle';
  s.textContent = emojis[Math.floor(Math.random()*emojis.length)];
  s.style.left = x + 'px';
  s.style.top = y + 'px';
  document.body.appendChild(s);
  setTimeout(() => s.remove(), 800);
}

function showToast(msg) {
  const t = document.createElement('div');
  t.style.cssText='position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1a0a0a;border:1px solid #ef4444;color:#ff8080;padding:10px 20px;border-radius:10px;z-index:9999;font-family:Rajdhani;font-size:.95rem;';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 2500);
}

// Init
updateUI();
renderCollection();
</script>
</body>
</html>
