<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anime Carta Gacha</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Orbitron:wght@400;700;900&family=Noto+Sans+JP:wght@400;700&display=swap');

:root {
  --bg: #04080f;
  --panel: #0a1220;
  --border: #1a2a3a;
  --common-c: #7a9bb0;
  --rare-c: #4a90e8;
  --epic-c: #a855f7;
  --legendary-c: #f59e0b;
  --mythic-c: #ef4444;
  --text: #c8d8e8;
  --gold: #fbbf24;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--bg);
  font-family: 'Rajdhani', sans-serif;
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Animated grid background */
body::before {
  content:'';
  position:fixed; inset:0;
  background-image:
    linear-gradient(#1a2a3a18 1px, transparent 1px),
    linear-gradient(90deg, #1a2a3a18 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events:none; z-index:0;
}

.wrapper { max-width: 900px; margin:0 auto; padding:16px; position:relative; z-index:1; }

/* Header */
.header {
  text-align:center;
  padding: 20px 0 16px;
  position: relative;
}
.header::after {
  content:'';
  display:block;
  width:200px; height:2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 12px auto 0;
}
.header h1 {
  font-family:'Orbitron', monospace;
  font-size: clamp(1.3rem, 4vw, 2rem);
  font-weight:900;
  background: linear-gradient(135deg, #fbbf24, #f97316, #ef4444);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  letter-spacing:3px;
  text-shadow: none;
}
.header p { font-size:.9rem; color:#5a7a9a; margin-top:6px; letter-spacing:1px; }

/* Currency bar */
.currency-bar {
  display:flex; gap:12px; justify-content:center; flex-wrap:wrap;
  margin-bottom:20px;
}
.coin-box {
  background: linear-gradient(135deg, #0a1a2a, #0d1f30);
  border:1px solid #1a3a5a;
  border-radius:10px;
  padding:8px 18px;
  display:flex; align-items:center; gap:8px;
  font-family:'Orbitron', monospace;
}
.coin-box .lbl { font-size:.65rem; color:#5a8aaa; text-transform:uppercase; letter-spacing:2px; }
.coin-box .val { font-size:1.1rem; color:var(--gold); font-weight:700; }

/* PULL button area */
.pull-area {
  display:flex; gap:10px; justify-content:center;
  margin-bottom:24px; flex-wrap:wrap;
}

.pull-btn {
  position:relative;
  padding:14px 28px;
  border:none; border-radius:12px;
  font-family:'Orbitron', monospace;
  font-size:.8rem; font-weight:700;
  letter-spacing:1px;
  cursor:pointer;
  overflow:hidden;
  transition: transform .15s, box-shadow .15s;
}
.pull-btn::before {
  content:'';
  position:absolute; inset:0;
  background: linear-gradient(135deg, rgba(255,255,255,.12), transparent);
  pointer-events:none;
}
.pull-btn:hover { transform:translateY(-3px); }
.pull-btn:active { transform:scale(.96); }

.btn-1 {
  background: linear-gradient(135deg, #1a3a5a, #0d2040);
  border:1px solid #2a5a8a;
  color:#7ab8e8;
  box-shadow: 0 4px 20px #1a4a7a40;
}
.btn-1:hover { box-shadow: 0 8px 30px #1a6aaa60; }

.btn-10 {
  background: linear-gradient(135deg, #4a2060, #2a0a40);
  border:1px solid #8a3aaa;
  color:#d080ff;
  box-shadow: 0 4px 20px #6a20a040;
}
.btn-10:hover { box-shadow: 0 8px 30px #9030c060; }

.btn-cost { font-size:.65rem; opacity:.7; margin-top:2px; }

/* Rates panel */
.rates-toggle {
  background:none; border:1px solid #1a3a5a; border-radius:8px;
  color:#5a8aaa; font-family:'Rajdhani',sans-serif;
  font-size:.85rem; padding:6px 16px; cursor:pointer;
  display:block; margin:0 auto 14px;
  transition: all .2s;
}
.rates-toggle:hover { border-color:#2a6aaa; color:#7ab8e8; }

.rates-panel {
  background:#0a1525;
  border:1px solid #1a2a3a;
  border-radius:12px;
  padding:14px 20px;
  margin-bottom:20px;
  display:none;
}
.rates-panel.open { display:block; }
.rates-grid { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; }
.rate-row {
  display:flex; align-items:center; gap:8px;
  background:#0d1a28; border-radius:8px; padding:6px 14px;
}
.rate-dot { width:10px; height:10px; border-radius:50%; }
.rate-name { font-size:.85rem; }
.rate-pct { font-size:.8rem; opacity:.6; margin-left:auto; }

/* Collection stats */
.coll-stats {
  display:flex; gap:8px; justify-content:center; flex-wrap:wrap;
  margin-bottom:20px;
}
.coll-stat {
  background:#0a1220;
  border:1px solid #1a2a3a;
  border-radius:8px;
  padding:6px 14px;
  font-size:.8rem;
  display:flex; align-items:center; gap:6px;
}

/* Roll animation overlay */
.roll-overlay {
  position:fixed; inset:0;
  background:#00000099;
  backdrop-filter:blur(6px);
  z-index:100;
  display:none;
  align-items:center; justify-content:center;
  flex-direction:column;
}
.roll-overlay.active { display:flex; }

.roll-cards-row {
  display:flex; gap:10px; flex-wrap:wrap; justify-content:center;
  max-width:820px; padding:20px;
}

/* Card styles */
.card {
  width:120px;
  border-radius:14px;
  overflow:hidden;
  position:relative;
  cursor:pointer;
  transform: scale(0) rotateY(180deg);
  animation: cardReveal .5s ease forwards;
  flex-shrink:0;
}
.card.revealed { transform: scale(1) rotateY(0deg); }

@keyframes cardReveal {
  0% { transform:scale(0) rotateY(180deg); opacity:0; }
  60% { transform:scale(1.1) rotateY(-5deg); opacity:1; }
  100% { transform:scale(1) rotateY(0deg); opacity:1; }
}

.card-inner {
  background: #0d1a28;
  border:2px solid;
  border-radius:14px;
  padding:8px;
  position:relative;
  overflow:hidden;
}

.card-inner::before {
  content:'';
  position:absolute; inset:0;
  background: linear-gradient(135deg, rgba(255,255,255,.05) 0%, transparent 60%);
  pointer-events:none;
}

/* Rarity colors */
.rarity-COMMON .card-inner   { border-color: var(--common-c); box-shadow: 0 0 10px #7a9bb020; }
.rarity-RARE .card-inner     { border-color: var(--rare-c);   box-shadow: 0 0 15px #4a90e840; }
.rarity-EPIC .card-inner     { border-color: var(--epic-c);   box-shadow: 0 0 20px #a855f760; }
.rarity-LEGENDARY .card-inner{ border-color: var(--legendary-c); box-shadow: 0 0 30px #f59e0b80; }
.rarity-MYTHIC .card-inner   { border-color: var(--mythic-c); box-shadow: 0 0 40px #ef444480, 0 0 80px #ef444430; }

/* Mythic animated border */
.rarity-MYTHIC .card-inner::after {
  content:'';
  position:absolute; inset:-2px;
  border-radius:14px;
  background: linear-gradient(45deg, #ef4444, #f97316, #fbbf24, #ef4444);
  background-size:300%;
  animation:borderSpin 2s linear infinite;
  z-index:-1;
}
@keyframes borderSpin { 0%{background-position:0%} 100%{background-position:300%} }

.card-emoji {
  font-size:2.8rem;
  text-align:center;
  display:block;
  padding:10px 0 6px;
  filter:drop-shadow(0 4px 8px rgba(0,0,0,.5));
}
.card-anime { font-size:.6rem; color:#5a8aaa; text-align:center; letter-spacing:1px; text-transform:uppercase; margin-bottom:2px; }
.card-name { font-family:'Orbitron',monospace; font-size:.7rem; font-weight:700; text-align:center; line-height:1.2; }
.card-rarity-badge {
  text-align:center;
  font-size:.6rem;
  letter-spacing:2px;
  text-transform:uppercase;
  font-weight:700;
  padding:3px 8px;
  border-radius:20px;
  margin:6px auto 4px;
  display:block;
  width:fit-content;
}
.rarity-COMMON   .card-rarity-badge { background:#7a9bb020; color:var(--common-c); }
.rarity-RARE     .card-rarity-badge { background:#4a90e820; color:var(--rare-c); }
.rarity-EPIC     .card-rarity-badge { background:#a855f720; color:var(--epic-c); }
.rarity-LEGENDARY .card-rarity-badge { background:#f59e0b20; color:var(--legendary-c); }
.rarity-MYTHIC   .card-rarity-badge { background:#ef444420; color:var(--mythic-c); animation:pulse .8s ease infinite; }

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.6} }

.card-power {
  display:flex; align-items:center; justify-content:center; gap:4px;
  font-size:.7rem; color:#5a8aaa; margin-bottom:4px;
}
.card-power .pw { font-family:'Orbitron',monospace; color:var(--gold); font-size:.8rem; }

.card-stars { text-align:center; font-size:.7rem; margin-bottom:4px; }

/* Confirm button in overlay */
.confirm-btn {
  background: linear-gradient(135deg, #1a3a6a, #0d2050);
  border:1px solid #3a6aaa;
  border-radius:12px;
  padding:12px 36px;
  color:#7ab8e8;
  font-family:'Orbitron',monospace;
  font-size:.85rem;
  cursor:pointer;
  margin-top:20px;
  transition: all .2s;
  letter-spacing:1px;
}
.confirm-btn:hover { background: linear-gradient(135deg, #2a4a8a, #1a3070); transform:translateY(-2px); }

/* Collection grid */
.section-title {
  font-family:'Orbitron',monospace;
  font-size:.8rem;
  letter-spacing:3px;
  color:#5a8aaa;
  text-transform:uppercase;
  margin-bottom:14px;
  display:flex; align-items:center; gap:10px;
}
.section-title::before, .section-title::after {
  content:''; flex:1; height:1px;
  background:linear-gradient(90deg, transparent, #1a3a5a);
}
.section-title::after { background:linear-gradient(90deg, #1a3a5a, transparent); }

.coll-grid {
  display:grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap:10px;
  margin-bottom:30px;
}

.coll-card {
  background:#0a1520;
  border:1px solid #1a2a3a;
  border-radius:10px;
  padding:8px;
  text-align:center;
  transition: all .2s;
  position:relative;
  cursor:default;
}
.coll-card:hover { transform:translateY(-3px); border-color:#2a4a6a; }

.coll-card .count-badge {
  position:absolute; top:5px; right:5px;
  background:#0d1a28;
  border:1px solid #1a3a5a;
  border-radius:20px;
  font-size:.6rem; padding:1px 5px;
  color:var(--gold);
  font-family:'Orbitron',monospace;
}

.empty-coll {
  text-align:center;
  padding:40px 20px;
  color:#2a4a6a;
  font-style:italic;
  border:1px dashed #1a2a3a;
  border-radius:12px;
}

/* Sparkle */
@keyframes sparklePop {
  0% { transform:scale(0) translateY(0); opacity:1; }
  100% { transform:scale(1.4) translateY(-60px); opacity:0; }
}
.sparkle {
  position:fixed; pointer-events:none;
  font-size:1.4rem;
  animation:sparklePop .7s ease forwards;
  z-index:999;
}

/* Filter tabs */
.filter-tabs {
  display:flex; gap:6px; flex-wrap:wrap;
  margin-bottom:14px; justify-content:center;
}
.filter-tab {
  padding:5px 14px;
  border-radius:20px;
  border:1px solid #1a2a3a;
  background:transparent;
  color:#5a8aaa;
  font-family:'Rajdhani',sans-serif;
  font-size:.85rem;
  cursor:pointer;
  transition:all .15s;
}
.filter-tab.active, .filter-tab:hover { border-color:#3a6aaa; color:#7ab8e8; background:#0d1a28; }
</style>
</head>
